@{
    ViewData["Title"] = "Asignar Mascota";
    var mascotas = ViewBag.Mascotas as List<EvaluacionContinua2.Models.Pet>;
}

<div class="container mt-5">
    <div class="card shadow p-4 rounded">
        <h3 class="mb-4 text-center text-primary">Asignar Mascota a Adoptante</h3>

        <form asp-action="Adoptar" method="post">
            <div class="mb-3">
                <label for="PetId" class="form-label">Mascota</label>
                <select id="PetId" name="PetId" class="form-select" required>
                    <option value="">-- Selecciona una mascota --</option>
                    @foreach (var pet in mascotas)
                    {
                        <option value="@pet.Id">@pet.Nombre (@pet.Tipo)</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label for="NombreAdoptante" class="form-label">Nombre del Adoptante</label>
                <input type="text" name="NombreAdoptante" id="NombreAdoptante" class="form-control" required />
            </div>

            <div class="text-center">
                <button type="submit" class="btn btn-primary">Asignar Adopción</button>
            </div>
        </form>
    </div>
</div>
